---
import Layout from "~/ui/components/layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => {
  const dateA = a.data.date?.getTime() ?? 0;
  const dateB = b.data.date?.getTime() ?? 0;
  return dateB - dateA;
});

const formatDate = (date?: Date) => {
  if (!date) return "";
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const [featured, ...rest] = posts;
---

<Layout title="Blog - TremTec" description="Insights on engineering excellence, AI-driven development, and scaling high-performance teams.">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-base-100 pt-16 pb-20">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute top-20 left-10 w-72 h-72 bg-primary rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-20 w-96 h-96 bg-secondary rounded-full blur-3xl"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-16">
        <p class="text-base font-semibold leading-7 text-primary mb-3">
          Our Blog
        </p>
        <h1 class="text-5xl font-extrabold tracking-tight text-base-content sm:text-6xl mb-6">
          Ideas & Insights
        </h1>
        <p class="text-xl leading-8 text-base-content/70">
          Engineering excellence, AI-driven development, and lessons from
          scaling high-performance teams.
        </p>
      </div>

      <!-- Featured Post -->
      {featured && (
        <a
          href={`/blog/${featured.id}`}
          class="group block relative overflow-hidden rounded-3xl bg-base-200 border border-base-300 hover:border-primary/40 transition-all duration-500 hover:shadow-2xl hover:shadow-primary/5"
        >
          <div class="p-8 sm:p-12 md:p-16">
            <div class="flex flex-wrap items-center gap-3 mb-6">
              <span class="badge badge-primary badge-sm font-semibold px-3 py-2.5">
                Latest
              </span>
              {featured.data.tags?.map((tag) => (
                <span class="badge badge-ghost badge-sm px-3 py-2.5">
                  {tag}
                </span>
              ))}
            </div>

            <h2 class="text-3xl sm:text-4xl font-bold text-base-content mb-4 group-hover:text-primary transition-colors duration-300">
              {featured.data.title}
            </h2>

            {featured.data.description && (
              <p class="text-lg text-base-content/60 max-w-2xl mb-8 leading-relaxed">
                {featured.data.description}
              </p>
            )}

            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                {featured.data.author && (
                  <span class="text-sm text-base-content/50">
                    {featured.data.author}
                  </span>
                )}
                {featured.data.date && (
                  <span class="text-sm text-base-content/40">
                    {formatDate(featured.data.date)}
                  </span>
                )}
              </div>

              <span class="inline-flex items-center gap-2 text-primary font-semibold group-hover:gap-3 transition-all duration-300">
                Read article
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      )}
    </div>
  </section>

  <!-- Post Grid -->
  {rest.length > 0 && (
    <section class="bg-base-200 py-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-base-content mb-12">
          More Articles
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {rest.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex flex-col overflow-hidden rounded-2xl bg-base-100 border border-base-300 hover:border-primary/30 transition-all duration-300 hover:shadow-xl hover:shadow-primary/5 hover:-translate-y-1"
            >
              <div class="flex-1 p-8">
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags?.map((tag) => (
                    <span class="text-xs font-medium text-primary/80 bg-primary/10 rounded-full px-3 py-1">
                      {tag}
                    </span>
                  ))}
                </div>

                <h3 class="text-xl font-bold text-base-content mb-3 group-hover:text-primary transition-colors duration-300 line-clamp-2">
                  {post.data.title}
                </h3>

                {post.data.description && (
                  <p class="text-base-content/60 text-sm leading-relaxed line-clamp-3">
                    {post.data.description}
                  </p>
                )}
              </div>

              <div class="px-8 pb-8 pt-0 flex items-center justify-between border-t border-base-200 mt-auto">
                <div class="flex items-center gap-3 pt-5">
                  {post.data.author && (
                    <span class="text-xs text-base-content/50">
                      {post.data.author}
                    </span>
                  )}
                  {post.data.date && (
                    <span class="text-xs text-base-content/40">
                      {formatDate(post.data.date)}
                    </span>
                  )}
                </div>

                <span class="pt-5 text-primary opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
                  </svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-base-100 py-20">
    <div class="mx-auto max-w-3xl px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-base-content mb-4">
        Want to work with us?
      </h2>
      <p class="text-lg text-base-content/60 mb-8">
        We help high-growth companies build trustworthy software faster.
      </p>
      <a href="/contact" class="btn btn-primary btn-lg px-8">
        Get Started
      </a>
    </div>
  </section>
</Layout>
