---
import "~/ui/styles/global.css";
import About from "~/ui/components/landing/About.astro";
import CTA from "~/ui/components/landing/CTA.astro";
import Hero from "~/ui/components/landing/Hero.astro";
import Methodology from "~/ui/components/landing/Methodology.astro";
import Services from "~/ui/components/landing/Services.astro";
