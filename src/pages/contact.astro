---
import ContactForm from "~/ui/components/ContactForm.astro";
import Layout from "~/ui/components/layouts/Layout.astro";
import { contactContent } from "~/ui/contents/contact";

const { metadata, hero, form, trustSignals } = contactContent;
---

<Layout title={metadata.title} description={metadata.description}>
  <div class="min-h-screen bg-gradient-to-br from-base-100 via-base-200 to-base-100">
    <div class="container mx-auto px-4 py-16 md:py-24">
      <!-- Hero Section -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-base-content mb-6">
          {hero.title}
        </h1>
        <p class="text-lg md:text-xl text-base-content/70 max-w-2xl mx-auto">
          {hero.subtitle}
        </p>
      </div>

      <!-- Contact Form Card -->
      <div class="max-w-2xl mx-auto">
        <div
          class="card bg-base-100/60 backdrop-blur-xl border border-white/10 shadow-2xl overflow-hidden relative group"
        >
          <!-- Glow effect on hover -->
          <div
            class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
          >
          </div>

          <div class="card-body p-8 md:p-12 relative z-10">
            <ContactForm
              fields={form.fields}
              submit={form.submit}
              successMessage={form.success}
              errorMessage={form.error}
            />
          </div>
        </div>

        <!-- Trust Signals -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
          {trustSignals.map((signal) => (
            <div class="flex items-center gap-4 p-4 rounded-xl bg-base-100/40 backdrop-blur-sm border border-white/5">
              <div class={`w-12 h-12 rounded-full bg-${signal.color}/10 flex items-center justify-center`}>
                {signal.icon === "clock" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class={`h-6 w-6 text-${signal.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
                {signal.icon === "shield" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class={`h-6 w-6 text-${signal.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                )}
                {signal.icon === "lock" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class={`h-6 w-6 text-${signal.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                  </svg>
                )}
              </div>
              <div>
                <h3 class="font-semibold text-base-content">{signal.title}</h3>
                <p class="text-sm text-base-content/60">{signal.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</Layout>
