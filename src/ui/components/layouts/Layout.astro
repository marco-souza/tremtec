---
import "~/ui/styles/global.css";

import { routes } from "~/server/contants";
import Footer from "~/ui/components/Footer.astro";
import Navbar from "~/ui/components/Navbar.astro";
import OpenGraph from "~/ui/components/OpenGraph.astro";
import { landingContent } from "~/ui/contents/landing";

const { navbar } = landingContent;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  hideNavbar?: boolean;
}

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href.startsWith("#") ? false : pathname.startsWith(href);

const {
  title = "TremTec",
  description = "TremTec Software Solutions",
  image = "/images/og-image.jpg",
  hideNavbar = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <OpenGraph title={title} description={description} image={image} />

    <title>{title}</title>
  </head>

  <body class="min-h-screen bg-base-100 text-base-content antialiased">
    <script>
      import 'htmx.org';
    </script>
    <div class="drawer">
      <input id="mobile-drawer" type="checkbox" class="drawer-toggle" />

      <div class="drawer-content flex flex-col min-h-screen">
        {hideNavbar 
          ? <slot />
          : (
            <Navbar />

            <!-- Content -->
            <div class="w-full flex-1 py-4 mt-20">
              <slot />
            </div>

            <Footer />
          )}
      </div>

      <div class="drawer-side z-50">
        <label for="mobile-drawer" class="drawer-overlay"></label>

        <ul class="menu p-4 w-80 min-h-full bg-base-200 gap-2 flex flex-col">
          <div class="spacer mt-4 mb-8">
            <a
              href={routes.public.home}
              class="flex dark:text-white items-center gap-2"
            >
              <img
                src="/images/logo.svg"
                width="48"
                height="48"
                alt={`${navbar.logo} Logo`}
              />
              <span class="text-lg font-bold">{navbar.logo}</span>
            </a>
          </div>

          {
            navbar.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={`text-lg font-medium ${isActive(link.href) ? "text-primary" : ""}`}
                  onclick="document.getElementById('mobile-drawer').click()"
                >
                  {link.label}
                </a>
              </li>
            ))
          }

          <div class="spacer flex-1"></div>

          <li class="mt-4 py-4 gap-4 flex flex-col border-t border-base-300">
            <a
              href={routes.public.login}
              class="text-lg font-medium"
              onclick="document.getElementById('mobile-drawer').click()"
            >
              {navbar.cta.login}
            </a>
            <a href="/contact" class="btn btn-primary btn-sm font-medium px-6">
              {navbar.cta.getStarted}
            </a>
          </li>
        </ul>
      </div>
    </div>
  </body>
</html>
